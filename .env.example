# ChainMed Backend Configuration
# Copy this file to .env and fill in your values

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/chainmed
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/chainmed

# JWT Secret (change this in production!)
JWT_SECRET=chainmed_super_secret_key_2026_change_this_in_production

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development